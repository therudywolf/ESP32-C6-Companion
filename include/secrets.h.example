/*
 * Nocturne C6 — WiFi, PC server & LLM credentials.
 * Copy to include/secrets.h and set your values. Do not commit secrets.h.
 */
#ifndef NOCTURNE_SECRETS_H
#define NOCTURNE_SECRETS_H

/* WiFi candidates. The device SCANS, ranks the known SSIDs by RSSI and
 * connects to the strongest; on failure it walks down the ranking. */
#define WIFI_NETWORKS                                                         \
  {                                                                           \
    {"HomeAP", "password1"},                                                  \
    {"PhoneHotspot", "password2"},                                            \
  }

/* PC telemetry server (Nocturne server, newline-delimited JSON over TCP).
 * LAN address of the PC running the server. */
#define PC_IP "192.168.1.2"
#define TCP_PORT 8888

/* Optional standalone fallback: an always-on endpoint serving a reduced payload
 * (weather + forest/services + clock) used when the PC server is unreachable.
 * Token-gated (sent as Authorization: Bearer) over HTTPS with a verified TLS
 * chain. Leave BOTH undefined to disable the fallback entirely. The endpoint
 * must serve a Let's Encrypt cert (the firmware pins ISRG Root X1). */
#define LITE_URL "https://your.host/nocturne/payload"
#define LITE_TOKEN "YOUR_TOKEN"

/* LM Studio (OpenAI-compatible) for the wolf's speech.
 * Endpoints are tried in order — put the LAN address first: from inside the
 * home network the public DDNS name is NOT reachable (hairpin NAT). The
 * public hostname is the fallback for when the device is on a hotspot.
 * NOTE: LM Studio >= 0.4 requires an API token (Developer > Server Settings
 * > Manage Tokens). */
#define LLM_ENDPOINTS                                                         \
  {                                                                           \
    "http://192.168.1.2:1234",                                                \
    "http://lmstudio.example.com",                                            \
  }
#define LLM_API_KEY "sk-lm-..."
#define LLM_MODEL "google/gemma-4-e2b"
#define LLM_MODEL_BIG "google/gemma-4-e2b"

#endif
